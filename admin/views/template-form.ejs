<%- include('partials/head') %>

<h1><%= template ? 'EDIT TEMPLATE' : 'NEW TEMPLATE' %></h1>

<div class="card">
  <form method="POST" action="<%= template ? '/templates/' + template.id : '/templates' %>" enctype="multipart/form-data">

    <div class="row">
      <div class="field">
        <label>Name</label>
        <input type="text" name="name" value="<%= template ? template.name : '' %>" required>
      </div>
      <div class="field">
        <label>Tier</label>
        <select name="tier">
          <% ['normal', 'synthetic', 'rare', 'michelle'].forEach(t => { %>
            <option value="<%= t %>" <%= template && template.tier === t ? 'selected' : '' %>><%= t.toUpperCase() %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div class="row-3">
      <div class="field">
        <label>Rarity Weight</label>
        <input type="number" name="rarity_weight" step="0.1" min="0" value="<%= template ? template.rarity_weight : 1 %>">
      </div>
      <div class="field">
        <label>Rare Type</label>
        <select name="rare_type">
          <option value="">None</option>
          <% ['hat', 'deformity', 'color'].forEach(t => { %>
            <option value="<%= t %>" <%= template && template.rare_type === t ? 'selected' : '' %>><%= t.toUpperCase() %></option>
          <% }) %>
        </select>
      </div>
      <div class="field">
        <label>Rare Trait</label>
        <input type="text" name="rare_trait" value="<%= template ? (template.rare_trait || '') : '' %>" placeholder="e.g. golden, 🎩, huge_head">
      </div>
    </div>

    <h2 style="margin-top: 24px;">Headshot</h2>

    <div class="row">
      <div class="field">
        <label>Upload Image</label>
        <input type="file" name="headshot" accept="image/*">
        <% if (template && template.headshot) { %>
          <div style="margin-top: 8px; display: flex; align-items: center; gap: 8px;">
            <img src="/uploads/<%= template.headshot %>" style="width: 48px; height: 48px; border-radius: 8px; object-fit: cover;">
            <span style="color: #666; font-size: 12px;">Current: <%= template.headshot %></span>
          </div>
        <% } %>
      </div>
      <div class="field">
        <label>Or use bundled asset name</label>
        <input type="text" name="headshot" value="<%= template ? (template.headshot || '') : '' %>" placeholder="e.g. michelle.png">
        <span style="font-size: 11px; color: #555;">Leave blank for default obama.png</span>
      </div>
    </div>

    <h2 style="margin-top: 24px;">Body Configuration</h2>

    <div class="row-3">
      <div class="field">
        <label>Arm Count</label>
        <input type="number" name="arm_count" min="0" max="8" value="<%= template ? template.arm_count : 2 %>">
      </div>
      <div class="field">
        <label>Leg Count</label>
        <input type="number" name="leg_count" min="0" max="8" value="<%= template ? template.leg_count : 2 %>">
      </div>
      <div class="field">
        <label>Body Color</label>
        <div style="display: flex; align-items: center; gap: 8px;">
          <input type="color" name="body_color" value="<%= template ? template.body_color : '#333333' %>">
          <span style="font-size: 12px; color: #666; font-family: monospace;"><%= template ? template.body_color : '#333333' %></span>
        </div>
      </div>
    </div>

    <div class="row-3">
      <div class="field">
        <label>Torso Length (multiplier)</label>
        <input type="number" name="torso_length" step="0.1" min="0.1" max="5" value="<%= template ? template.torso_length : 1 %>">
      </div>
      <div class="field">
        <label>Arm Length (multiplier)</label>
        <input type="number" name="arm_length" step="0.1" min="0.1" max="5" value="<%= template ? template.arm_length : 1 %>">
      </div>
      <div class="field">
        <label>Leg Length (multiplier)</label>
        <input type="number" name="leg_length" step="0.1" min="0.1" max="5" value="<%= template ? template.leg_length : 1 %>">
      </div>
    </div>

    <% if (accessories.length > 0) { %>
    <h2 style="margin-top: 24px;">Accessories</h2>
    <div class="field">
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 8px;">
        <% accessories.forEach(a => { %>
          <label style="display: flex; align-items: center; gap: 8px; padding: 8px; background: #111; border: 1px solid #222; border-radius: 8px; cursor: pointer; font-size: 13px;">
            <input type="checkbox" name="accessories" value="<%= a.id %>" <%= attached.includes(a.id) ? 'checked' : '' %>>
            <img src="/uploads/<%= a.image %>" style="width: 28px; height: 28px; border-radius: 4px; object-fit: cover;">
            <span><%= a.name %></span>
            <span style="color: #555; font-size: 10px;">(<%= a.attach_point %>)</span>
          </label>
        <% }) %>
      </div>
    </div>
    <% } %>

    <div style="margin-top: 24px; display: flex; gap: 8px;">
      <button type="submit" class="btn btn-primary"><%= template ? 'Save Changes' : 'Create Template' %></button>
      <a href="/templates" class="btn">Cancel</a>
    </div>
  </form>
</div>

<%- include('partials/foot') %>
