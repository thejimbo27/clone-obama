<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Obama Admin</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      background: #0a0a0a; color: #e0e0e0; line-height: 1.6;
    }
    a { color: #4a9eff; text-decoration: none; }
    a:hover { text-decoration: underline; }

    .nav {
      background: #111; border-bottom: 1px solid #222;
      padding: 12px 24px; display: flex; align-items: center; gap: 24px;
    }
    .nav-brand { font-size: 14px; font-weight: 600; color: #ff3b30; letter-spacing: 4px; }
    .nav a { color: #888; font-size: 13px; letter-spacing: 1px; }
    .nav a:hover, .nav a.active { color: #fff; text-decoration: none; }

    .container { max-width: 1100px; margin: 0 auto; padding: 24px; }

    h1 { font-size: 20px; font-weight: 300; letter-spacing: 6px; color: #fff; margin-bottom: 24px; }
    h2 { font-size: 14px; font-weight: 500; letter-spacing: 3px; color: #888; margin-bottom: 16px; text-transform: uppercase; }

    .card {
      background: #141414; border: 1px solid #222; border-radius: 12px;
      padding: 20px; margin-bottom: 16px;
    }

    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; }
    .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px; }

    .stat-card {
      background: #141414; border: 1px solid #222; border-radius: 10px;
      padding: 16px; text-align: center;
    }
    .stat-num { font-size: 28px; font-weight: 200; color: #fff; font-family: monospace; }
    .stat-label { font-size: 9px; color: #666; letter-spacing: 3px; margin-top: 4px; }

    table { width: 100%; border-collapse: collapse; }
    th { font-size: 10px; color: #666; letter-spacing: 2px; text-align: left; padding: 8px 12px; border-bottom: 1px solid #222; }
    td { padding: 10px 12px; border-bottom: 1px solid #1a1a1a; font-size: 13px; }
    tr:hover { background: #1a1a1a; }

    .badge {
      display: inline-block; padding: 2px 8px; border-radius: 4px;
      font-size: 10px; letter-spacing: 1px; font-weight: 600;
    }
    .badge-normal { background: #222; color: #888; }
    .badge-synthetic { background: #1a2a3a; color: #6b9fc8; }
    .badge-rare { background: #2a2200; color: #b8860b; }
    .badge-michelle { background: #2a1020; color: #ff69b4; }

    .btn {
      display: inline-block; padding: 8px 16px; border-radius: 8px;
      border: 1px solid #333; background: #1a1a1a; color: #ddd;
      font-size: 12px; letter-spacing: 1px; cursor: pointer; transition: all 0.15s;
    }
    .btn:hover { background: #222; border-color: #444; text-decoration: none; }
    .btn-primary { border-color: #4a9eff44; color: #4a9eff; }
    .btn-primary:hover { background: #4a9eff11; }
    .btn-danger { border-color: #ff3b3044; color: #ff3b30; }
    .btn-danger:hover { background: #ff3b3011; }
    .btn-sm { padding: 4px 10px; font-size: 11px; }

    form .field { margin-bottom: 16px; }
    form label { display: block; font-size: 10px; color: #666; letter-spacing: 2px; margin-bottom: 6px; text-transform: uppercase; }
    form input[type="text"], form input[type="number"], form select {
      width: 100%; padding: 10px 14px; background: #111; border: 1px solid #222;
      border-radius: 8px; color: #ddd; font-size: 14px;
    }
    form input[type="color"] { width: 60px; height: 36px; border: 1px solid #222; border-radius: 6px; background: #111; cursor: pointer; }
    form input[type="file"] { color: #888; font-size: 13px; }
    form .row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    form .row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

    .thumb { width: 40px; height: 40px; border-radius: 6px; object-fit: cover; background: #222; }
    .actions { display: flex; gap: 6px; }

    .flash { padding: 12px 16px; background: #1a2a1a; border: 1px solid #2a4a2a; border-radius: 8px; color: #4a9; margin-bottom: 16px; font-size: 13px; }
  </style>
</head>
<body>
  <nav class="nav">
    <span class="nav-brand">OBAMA ADMIN</span>
    <a href="/">Dashboard</a>
    <a href="/templates">Templates</a>
    <a href="/accessories">Accessories</a>
  </nav>
  <div class="container">
